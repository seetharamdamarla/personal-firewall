# ============================================================
# Personal Firewall — Custom Suricata Rules
# ============================================================
# File: /etc/suricata/rules/personal-firewall.rules
# These rules detect common attack patterns from the Kali lab.
# SID range: 1000001–1000099 (custom local rules)
# ============================================================


# ──────────────────────────────────────────────────────────────
# 1. PORT SCAN DETECTION
# ──────────────────────────────────────────────────────────────

# Detect TCP SYN scan (Nmap -sS) — multiple SYN packets without completing handshake
# Triggers when a single source sends SYN to 5+ different ports within 60 seconds
alert tcp any any -> $HOME_NET any (msg:"PF — TCP Port Scan Detected (5+ ports in 60s)"; flags:S,12; threshold:type both, track by_src, count 5, seconds 60; classtype:attempted-recon; sid:1000001; rev:1;)

# Detect aggressive port scan — 20+ ports in 30 seconds
alert tcp any any -> $HOME_NET any (msg:"PF — Aggressive TCP Port Scan (20+ ports in 30s)"; flags:S,12; threshold:type both, track by_src, count 20, seconds 30; classtype:attempted-recon; sid:1000002; rev:1; priority:1;)

# Detect NULL scan (Nmap -sN) — no flags set
alert tcp any any -> $HOME_NET any (msg:"PF — TCP NULL Scan Detected"; flags:0,12; threshold:type both, track by_src, count 3, seconds 60; classtype:attempted-recon; sid:1000003; rev:1;)

# Detect XMAS scan (Nmap -sX) — FIN+PSH+URG flags set
alert tcp any any -> $HOME_NET any (msg:"PF — TCP XMAS Scan Detected"; flags:FPU,12; threshold:type both, track by_src, count 3, seconds 60; classtype:attempted-recon; sid:1000004; rev:1;)

# Detect FIN scan (Nmap -sF) — only FIN flag set
alert tcp any any -> $HOME_NET any (msg:"PF — TCP FIN Scan Detected"; flags:F,12; threshold:type both, track by_src, count 3, seconds 60; classtype:attempted-recon; sid:1000005; rev:1;)


# ──────────────────────────────────────────────────────────────
# 2. SYN FLOOD DETECTION
# ──────────────────────────────────────────────────────────────

# SYN flood — 100+ SYN packets from same source in 10 seconds
alert tcp any any -> $HOME_NET any (msg:"PF — SYN Flood Attack Detected (100+ SYN in 10s)"; flags:S,12; threshold:type both, track by_src, count 100, seconds 10; classtype:attempted-dos; sid:1000010; rev:1; priority:1;)

# SYN flood targeting specific port (HTTP)
alert tcp any any -> $HOME_NET 80 (msg:"PF — SYN Flood on HTTP Port 80"; flags:S,12; threshold:type both, track by_src, count 50, seconds 10; classtype:attempted-dos; sid:1000011; rev:1; priority:1;)

# SYN flood targeting SSH
alert tcp any any -> $HOME_NET 22 (msg:"PF — SYN Flood on SSH Port 22"; flags:S,12; threshold:type both, track by_src, count 50, seconds 10; classtype:attempted-dos; sid:1000012; rev:1; priority:1;)


# ──────────────────────────────────────────────────────────────
# 3. SSH BRUTE FORCE DETECTION
# ──────────────────────────────────────────────────────────────

# SSH connection attempts — 5+ from same IP in 30 seconds
alert tcp any any -> $HOME_NET 22 (msg:"PF — SSH Brute Force Attempt (5+ in 30s)"; flags:S,12; threshold:type both, track by_src, count 5, seconds 30; classtype:attempted-admin; sid:1000020; rev:1; priority:1;)

# SSH connection attempts — 10+ from same IP in 60 seconds (confirmed brute force)
alert tcp any any -> $HOME_NET 22 (msg:"PF — SSH Brute Force Confirmed (10+ in 60s)"; flags:S,12; threshold:type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:1000021; rev:1; priority:1;)


# ──────────────────────────────────────────────────────────────
# 4. ICMP FLOOD DETECTION
# ──────────────────────────────────────────────────────────────

# ICMP flood — 50+ ping packets in 10 seconds
alert icmp any any -> $HOME_NET any (msg:"PF — ICMP Flood Detected (50+ in 10s)"; itype:8; threshold:type both, track by_src, count 50, seconds 10; classtype:attempted-dos; sid:1000030; rev:1; priority:1;)

# Large ICMP packets (potential ping of death or exfiltration)
alert icmp any any -> $HOME_NET any (msg:"PF — Oversized ICMP Packet (>1000 bytes)"; itype:8; dsize:>1000; classtype:attempted-dos; sid:1000031; rev:1;)


# ──────────────────────────────────────────────────────────────
# 5. GENERAL SUSPICIOUS ACTIVITY
# ──────────────────────────────────────────────────────────────

# UDP flood — 100+ UDP packets in 10 seconds
alert udp any any -> $HOME_NET any (msg:"PF — UDP Flood Detected (100+ in 10s)"; threshold:type both, track by_src, count 100, seconds 10; classtype:attempted-dos; sid:1000040; rev:1; priority:1;)

# Detect Nmap OS fingerprinting (unusual TCP window + flags combo)
alert tcp any any -> $HOME_NET any (msg:"PF — Possible Nmap OS Fingerprint Probe"; flags:SFPAU; classtype:attempted-recon; sid:1000041; rev:1;)
