# ================================================
# Personal Firewall — Environment Variables
# ================================================
# Copy this file to .env and fill in your values

# ── Lab Network IPs ──
UBUNTU_SERVER_IP=172.16.206.50
KALI_IP=172.16.206.60
GATEWAY_IP=172.16.206.153

# ── Ubuntu Server Network Interface ──
SNIFFER_IFACE=enp0s1

# ── API Keys (Phase 5) ──
ABUSEIPDB_API_KEY=your_key_here
SHODAN_API_KEY=your_key_here

# ── Splunk (Phase 4) ──
SPLUNK_HOST=172.16.206.50
SPLUNK_PORT=8089
SPLUNK_USER=admin
SPLUNK_PASS=changeme

# ── Wazuh (Phase 3) ──
WAZUH_API_HOST=172.16.206.50
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=changeme
